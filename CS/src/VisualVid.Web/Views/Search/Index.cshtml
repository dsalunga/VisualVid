@model SearchResultsViewModel
@{
    ViewData["Title"] = "Search Results";
}

<h2>Search Results for "@Model.Query"</h2>

@if (Model.Videos.Any())
{
    <p>@Model.Videos.Count result(s) found.</p>
    <div class="row">
        @foreach (var video in Model.Videos)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100">
                    <a href="@Url.Action("Watch", "Video", new { videoId = video.VideoId })">
                        <img src="@video.ThumbnailUrl" class="card-img-top" alt="@video.Title"
                             onerror="this.src='/images/img_novideo.jpg'" />
                    </a>
                    <div class="card-body">
                        <h6 class="card-title">
                            <a href="@Url.Action("Watch", "Video", new { videoId = video.VideoId })" class="text-decoration-none">
                                @video.Title
                            </a>
                        </h6>
                        <p class="card-text text-muted small">
                            By <a href="@Url.Action("Index", "Profile", new { userId = video.UserId })">@video.UserName</a><br />
                            @video.Views views &middot; @video.DateAdded
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">No results found for your search.</p>
}
