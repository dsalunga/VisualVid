@model BrowseViewModel
@{
    ViewData["Title"] = "Browse Videos";
}

<h2>Browse Videos</h2>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" class="d-flex gap-2">
            <select name="categoryId" class="form-select" style="max-width: 200px;">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.CategoryId" selected="@(cat.CategoryId == Model.SelectedCategoryId)">@cat.Name</option>
                }
            </select>
            <select name="sort" class="form-select" style="max-width: 200px;">
                <option value="newest" selected="@(Model.Sort == "newest")">Newest</option>
                <option value="views" selected="@(Model.Sort == "views")">Most Viewed</option>
                <option value="title" selected="@(Model.Sort == "title")">Title</option>
            </select>
            <button type="submit" class="btn btn-primary">Filter</button>
        </form>
    </div>
</div>

<div class="row">
    @foreach (var video in Model.Videos)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100">
                <a href="@Url.Action("Watch", "Video", new { videoId = video.VideoId })">
                    <img src="@video.ThumbnailUrl" class="card-img-top" alt="@video.Title"
                         onerror="this.src='/images/img_novideo.jpg'" />
                </a>
                <div class="card-body">
                    <h6 class="card-title">
                        <a href="@Url.Action("Watch", "Video", new { videoId = video.VideoId })" class="text-decoration-none">
                            @video.Title
                        </a>
                    </h6>
                    <p class="card-text text-muted small">
                        By <a href="@Url.Action("Index", "Profile", new { userId = video.UserId })">@video.UserName</a><br />
                        @video.Views views &middot; @video.DateAdded
                    </p>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Videos.Any())
{
    <p class="text-muted">No videos found.</p>
}
