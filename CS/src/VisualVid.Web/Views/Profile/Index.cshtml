@model PublicProfileViewModel
@{
    ViewData["Title"] = Model.UserName + "'s Profile";
}

<div class="row">
    <div class="col-md-3 text-center">
        <img src="@Model.PhotoUrl" alt="@Model.UserName" class="img-fluid rounded-circle mb-3" style="max-width:150px;"
             onerror="this.src='/images/img_userpic.jpg'" />
        <h4>@Model.UserName</h4>
        @if (!string.IsNullOrEmpty(Model.Location))
        {
            <p class="text-muted">@Model.Location</p>
        }
        <p class="text-muted small">Member since @Model.MemberSince</p>
    </div>
    <div class="col-md-9">
        @if (!string.IsNullOrEmpty(Model.AboutMe))
        {
            <h5>About</h5>
            <p>@Model.AboutMe</p>
        }

        <h5>Videos (@Model.Videos.Count)</h5>
        <div class="row">
            @foreach (var video in Model.Videos)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <a href="@Url.Action("Watch", "Video", new { videoId = video.VideoId })">
                            <img src="@video.ThumbnailUrl" class="card-img-top" alt="@video.Title"
                                 onerror="this.src='/images/img_novideo.jpg'" />
                        </a>
                        <div class="card-body">
                            <h6 class="card-title">
                                <a href="@Url.Action("Watch", "Video", new { videoId = video.VideoId })" class="text-decoration-none">
                                    @video.Title
                                </a>
                            </h6>
                            <p class="card-text text-muted small">@video.Views views</p>
                        </div>
                    </div>
                </div>
            }
        </div>
        @if (!Model.Videos.Any())
        {
            <p class="text-muted">No videos uploaded yet.</p>
        }
    </div>
</div>
