@{
    ViewData["Title"] = "Email Confirmed";
    var success = ViewBag.Success as bool? ?? false;
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        @if (success)
        {
            <h2>Email Confirmed</h2>
            <p class="lead">Your email address has been confirmed successfully.</p>
            <a asp-action="Login" class="btn btn-primary">Login Now</a>
        }
        else
        {
            <h2>Confirmation Failed</h2>
            <p class="text-danger">The confirmation link is invalid or has expired.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Go to Home</a>
        }
    </div>
</div>
