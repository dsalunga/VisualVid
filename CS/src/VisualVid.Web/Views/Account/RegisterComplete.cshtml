@{
    ViewData["Title"] = "Registration Complete";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center">
        <h2>Registration Complete</h2>
        <p class="lead">Your account has been created successfully.</p>
        <p>A confirmation email has been sent to your email address. Please check your inbox to activate your account.</p>
        <a asp-action="Login" class="btn btn-primary">Go to Login</a>
    </div>
</div>
