@model MemberDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

<h2>My Dashboard</h2>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">@Model.TotalVideos</h5>
                <p class="card-text text-muted">Videos</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">@Model.TotalViews</h5>
                <p class="card-text text-muted">Total Views</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 text-end">
        <a asp-controller="Video" asp-action="Upload" class="btn btn-primary">Upload Video</a>
        <a asp-controller="Profile" asp-action="Edit" class="btn btn-outline-secondary">Edit Profile</a>
    </div>
</div>

<h4>My Videos</h4>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Views</th>
            <th>Date Added</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var video in Model.Videos)
        {
            <tr>
                <td>
                    <a href="@Url.Action("Watch", "Video", new { area = "", videoId = video.VideoId })">@video.Title</a>
                </td>
                <td>
                    @if (video.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">Pending</span>
                    }
                </td>
                <td>@video.Views</td>
                <td>@video.DateAdded</td>
                <td>
                    <a asp-controller="Video" asp-action="Edit" asp-route-id="@video.VideoId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-controller="Video" asp-action="Delete" asp-route-id="@video.VideoId" method="post" class="d-inline"
                          onsubmit="return confirm('Are you sure you want to delete this video?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Videos.Any())
{
    <p class="text-muted">You haven't uploaded any videos yet.</p>
}
